{
	"name": "n8n-nodes-nalu-ai",
	"version": "0.2.0",
	"description": "n8n Community Node for NaLU AI - Semantic NLU data validation and extraction for chatbots.",
	"license": "MIT",
	"homepage": "https://naluai.dev",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "NaLU AI Team",
		"email": "contato@naluai.dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/naluai/n8n-nodes-nalu-ai.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/NaluAiApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/NaluAi/NaluAi.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
